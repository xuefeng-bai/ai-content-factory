# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./data/content_factory.db

# ==================== AI 配置 ====================
DASHSCOPE_API_KEY=sk-your-api-key
AI_MODEL=qwen-plus

# ==================== AI 调用超时配置（秒） ====================
# 文本生成超时时间
AI_TEXT_TIMEOUT=30
# 图片生成超时时间
AI_IMAGE_TIMEOUT=60

# ==================== 重试机制配置 ====================
# 最大重试次数
AI_MAX_RETRIES=3
# 重试间隔基数（秒），使用指数退避：base * 2^attempt
AI_RETRY_BASE_DELAY=1

# ==================== Prompt 缓存配置 ====================
# 是否启用缓存（true/false）
PROMPT_CACHE_ENABLED=true
# 缓存过期时间（秒）
PROMPT_CACHE_TTL=300

# ==================== 生成参数配置 ====================
# 默认最大 token 数
AI_MAX_TOKENS=2000
# 默认温度参数（0-1，越高越随机）
AI_TEMPERATURE=0.7

# ==================== 服务配置 ====================
HOST=0.0.0.0
PORT=8000

# ==================== 日志配置 ====================
LOG_LEVEL=INFO

# ==================== 跨平台适配 ====================
# 所有路径使用 pathlib 处理，不要硬编码路径分隔符
# 所有文件使用 UTF-8 编码
# 命令行使用 python 命令，不要指定版本
